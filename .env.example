NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_BASIC_MODEL=deepseek-v4-flash
DEEPSEEK_PREMIUM_MODEL=deepseek-v4-pro
AI_BASIC_BUDGET_USD=0.03
AI_PREMIUM_BUDGET_USD=0.15

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PITCH_PACK=
STRIPE_PRICE_BUILDER=
STRIPE_PRICE_ADDON_PACK=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_PREMIUM_ENABLED=false

# Optional fallback provider while DeepSeek is not configured.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Protects the durable worker endpoint. Vercel Cron sends this as a Bearer token.
CRON_SECRET=
PITCH_WORKER_BATCH_SIZE=1

# Keep source media below the transcription provider's 25 MB request limit.
MAX_VIDEO_BYTES=25165824
MAX_DECK_BYTES=52428800
