NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_BASIC_MODEL=deepseek-v4-flash
DEEPSEEK_PREMIUM_MODEL=deepseek-v4-pro
AI_BASIC_BUDGET_USD=0.03
AI_PREMIUM_BUDGET_USD=0.15

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PITCH_PACK=
STRIPE_PRICE_BUILDER=
STRIPE_PRICE_ADDON_PACK=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_PREMIUM_ENABLED=false

# Optional fallback provider while DeepSeek is not configured.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# 5-minute videos are capped at 250 MB by default.
MAX_VIDEO_BYTES=262144000
MAX_DECK_BYTES=52428800
